    Finished `dev` profile [unoptimized + debuginfo] target(s) in 0.13s
     Running `target/debug/xtask lima run -- bash -lc '
set -uo pipefail
WORK="$(mktemp -d)"
DATA="$WORK/data"; CONF="$WORK/conf"; CREDS="$WORK/creds"
mkdir -p "$DATA" "$CONF" "$CREDS"
KEK_ID="overdrive-ca-root"
INTENT="$DATA/intent.redb"
head -c 32 /dev/zero | tr "\0" "\\377" > "$CREDS/$KEK_ID"   # 32 raw bytes (0xFF)

serve() { # <timeout_secs>
  CREDENTIALS_DIRECTORY="$CREDS" OVERDRIVE_CONFIG_DIR="$CONF" \
    timeout --preserve-status -s INT "${1}s" \
    cargo run -q -p overdrive-cli --bin overdrive -- serve --bind 127.0.0.1:0 --data-dir "$DATA" \
    >> "$WORK/serve.out" 2>&1 || true
}

rc=0

# --- First boot: generate + seal + persist the root. -------------------------
serve 25
if [ '\!' -f "$INTENT" ]; then
  echo "  [FAIL] first boot did not persist $INTENT"
  sed -n "1,40p" "$WORK/serve.out"
  rm -rf "$WORK"; exit 1
fi
echo "  [PASS] first boot persisted the IntentStore at $INTENT"

scan_plaintext() { # echoes the count of plaintext PRIVATE KEY PEM markers
  # Count co-occurrence of the BEGIN armor AND the PRIVATE KEY armor. The sealed
  # plaintext (PEM) would show both verbatim if persisted un-sealed.
  local begins privkeys
  begins=$(grep -a -c -- "-----BEGIN" "$INTENT" 2>/dev/null || echo 0)
  privkeys=$(grep -a -c -- "PRIVATE KEY-----" "$INTENT" 2>/dev/null || echo 0)
  echo "$begins $privkeys"
}

read -r b1 p1 <<<"$(scan_plaintext)"
if [ "$b1" -gt 0 ] && [ "$p1" -gt 0 ]; then
  echo "  [FAIL] sub-claim 1: plaintext PRIVATE KEY PEM found on disk (BEGIN=$b1 PRIVKEY=$p1)"; rc=1
else
  echo "  [PASS] sub-claim 1: zero plaintext PRIVATE KEY PEM in $INTENT (BEGIN=$b1 PRIVKEY=$p1)"
fi

# Sub-claim 2 — the sealed envelope IS present (key sealed, not absent): the
# IntentStore carries the envelope key marker and is non-trivially sized.
if grep -aq "key-envelope" "$INTENT" 2>/dev/null && [ -s "$INTENT" ]; then
  echo "  [PASS] sub-claim 2: sealed root-key envelope present in the IntentStore"
else
  echo "  [FAIL] sub-claim 2: no sealed root-key envelope present"; rc=1
fi

# --- Restart (decrypt + adopt the SAME root), re-scan. -----------------------
serve 25
read -r b2 p2 <<<"$(scan_plaintext)"
if [ "$b2" -gt 0 ] && [ "$p2" -gt 0 ]; then
  echo "  [FAIL] sub-claim 3: plaintext PRIVATE KEY PEM appeared after restart (BEGIN=$b2 PRIVKEY=$p2)"; rc=1
else
  echo "  [PASS] sub-claim 3: still zero plaintext PRIVATE KEY PEM after restart (BEGIN=$b2 PRIVKEY=$p2)"
fi

rm -rf "$WORK"
exit $rc
'`
